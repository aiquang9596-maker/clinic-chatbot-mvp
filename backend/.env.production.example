# ============================================================
# Railway / Cloud Production Environment Variables
# Set these in Railway dashboard → Variables tab
# ============================================================

# Meta / Messenger
MESSENGER_VERIFY_TOKEN=clinic_ms_verify_2024
MESSENGER_PAGE_ACCESS_TOKEN=<paste from Meta dashboard>
MESSENGER_APP_SECRET=<paste from Meta dashboard → App Settings → Basic>

# Meta / WhatsApp (khi setup xong)
WHATSAPP_VERIFY_TOKEN=clinic_wa_verify_2024
WHATSAPP_ACCESS_TOKEN=<paste from Meta dashboard>
WHATSAPP_PHONE_NUMBER_ID=<paste from Meta dashboard>
WHATSAPP_WABA_ID=<paste from Meta dashboard>

# Database — Railway tự inject DATABASE_URL khi add PostgreSQL plugin
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# App
SECRET_KEY=<random 32 chars — generate: python -c "import secrets; print(secrets.token_hex(16))">
DEBUG=false

# AI — Railway không chạy Ollama local
# Để trống hoặc dùng Claude API khi sẵn sàng upgrade
OLLAMA_BASE_URL=
OLLAMA_MODEL=phi3:mini
AI_MODE=suggest
AI_CONFIDENCE_THRESHOLD=0.85

# Safety
AUTO_REPLY_ENABLED=false
