# ==== META / WhatsApp Cloud API ====
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_waba_id

# ==== META / Messenger Page API ====
MESSENGER_VERIFY_TOKEN=your_verify_token_here
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token
MESSENGER_APP_SECRET=your_app_secret

# ==== APP ====
SECRET_KEY=changeme_random_32chars
DEBUG=true
DATABASE_URL=sqlite:///./data/chatbot.db

# ==== AI / Ollama ====
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
AI_MODE=suggest            # suggest | limited_auto | off
AI_CONFIDENCE_THRESHOLD=0.85

# ==== Safety ====
AUTO_REPLY_ENABLED=false   # default OFF; enable only after testing
